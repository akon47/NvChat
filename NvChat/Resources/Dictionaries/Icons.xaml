    <!-- 아이콘 Path 기본 스타일: 24x24 지오메트리를 Stretch 로 맞추고, 색은 가까운 Control(버튼 등)의 Foreground 를 따른다. -->
    <Style x:Key="IconStyle" TargetType="{x:Type Path}">
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Control}}}" />
    </Style>

