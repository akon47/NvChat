<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    >
    <!-- ===== 베이스(Gaia 다크 팔레트) ===== -->
    <Color x:Key="WindowBackgroundColor">#1E1E1F</Color>
    <Color x:Key="TitleBarBackgroundColor">#191919</Color>
    <Color x:Key="PanelBackgroundColor">#1A1A1B</Color>
    <Color x:Key="CardBackgroundColor">#252526</Color>
    <Color x:Key="ControlBackgroundColor">#2A2A2B</Color>
    <Color x:Key="ControlHoverBackgroundColor">#323234</Color>

    <Color x:Key="ForegroundColor">#F2F2F3</Color>
    <Color x:Key="SecondaryForegroundColor">#9EA2AE</Color>
    <Color x:Key="MutedForegroundColor">#6E7178</Color>

    <Color x:Key="BorderColor">#333336</Color>
    <Color x:Key="BorderStrongColor">#45454A</Color>

    <!-- ===== 액센트(NVIDIA 그린) ===== -->
    <Color x:Key="AccentColor">#76B900</Color>
    <Color x:Key="AccentHoverColor">#88CF12</Color>
    <Color x:Key="AccentPressedColor">#5F9600</Color>
    <Color x:Key="AccentForegroundColor">#0A0F02</Color>

    <!-- ===== 말풍선 ===== -->
    <Color x:Key="UserBubbleBackgroundColor">#2A3A17</Color>
    <Color x:Key="UserBubbleBorderColor">#3F5F1E</Color>
    <Color x:Key="AssistantBubbleBackgroundColor">#232324</Color>
    <Color x:Key="AssistantBubbleBorderColor">#2F2F31</Color>

    <!-- ===== 코드 ===== -->
    <Color x:Key="CodeBlockBackgroundColor">#141415</Color>
    <Color x:Key="CodeHeaderBackgroundColor">#202022</Color>
    <Color x:Key="CodeForegroundColor">#E6E6E6</Color>
    <Color x:Key="InlineCodeBackgroundColor">#2A2A2B</Color>
    <Color x:Key="InlineCodeForegroundColor">#C5E17A</Color>

    <!-- ===== 상태 ===== -->
    <Color x:Key="ErrorColor">#E5534B</Color>
    <Color x:Key="SuccessColor">#5FB760</Color>
    <Color x:Key="WarnColor">#F0A020</Color>

    <!-- ===== 스크롤/오버레이 ===== -->
    <Color x:Key="ScrollThumbColor">#3C3C40</Color>
    <Color x:Key="ScrollThumbHoverColor">#50505A</Color>
    <Color x:Key="WhiteColor">#FFFFFF</Color>
    <Color x:Key="CloseHoverColor">#E5534B</Color>

</ResourceDictionary>
