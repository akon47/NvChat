<views:WindowView
    x:Class="NvChat.Views.ConfirmDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:NvChat.Views"
    Title="확인"
    Width="430"
    SizeToContent="Height"
    ResizeMode="NoResize"
    ShowMinimizeButton="False"
    ShowMaximizeButton="False"
    Style="{StaticResource NvWindowStyle}"
    WindowStartupLocation="CenterOwner"
    >
    <StackPanel Margin="22,18,22,16">
        <TextBlock x:Name="MessageText"
                   Foreground="{StaticResource ForegroundBrush}"
                   TextWrapping="Wrap"
                   FontSize="13.5"
                   LineHeight="21" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
            <Button Content="취소" Click="Cancel_Click" Padding="18,8" Margin="0,0,10,0" IsCancel="True" />
            <Button Content="삭제" Click="Confirm_Click" Style="{StaticResource AccentButtonStyle}" Padding="22,8" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</views:WindowView>
