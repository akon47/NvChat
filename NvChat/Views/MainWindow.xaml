<views:WindowView
    x:Class="NvChat.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:NvChat.Views"
    xmlns:vm="clr-namespace:NvChat.ViewModels"
    xmlns:controls="clr-namespace:NvChat.Controls"
    xmlns:behaviors="clr-namespace:NvChat.Behaviors"
    mc:Ignorable="d"
    Title="NvChat"
    ShowTitleText="False"
    Width="1160"
    Height="780"
    MinWidth="900"
    MinHeight="580"
    Style="{StaticResource NvWindowStyle}"
    WindowStartupLocation="CenterScreen"
    d:DataContext="{d:DesignInstance vm:MainViewModel}"
    >

    <views:WindowView.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewConversationCommand}" />
    </views:WindowView.InputBindings>

    <!-- ================= 타이틀바: 사이드바 토글 + 모델 선택기 + 설정 ================= -->
    <views:WindowView.TitleBarContent>
        <Grid Margin="4,0,4,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Command="{Binding ToggleSidebarCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" ToolTip="사이드바 토글">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSidebar}" Width="18" Height="18" />
                </Button>

                <!-- 모델 선택기 -->
                <Button x:Name="ModelPickerButton" Command="{Binding ToggleModelPickerCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="10,6" Margin="4,0,0,0" ToolTip="모델 선택">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconChat}" Width="15" Height="15" Margin="0,0,7,0" />
                        <TextBlock Text="{Binding SelectedModel.Name, TargetNullValue='모델 선택', FallbackValue='모델 선택'}" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center" MaxWidth="280" TextTrimming="CharacterEllipsis" />
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconChevronDown}" Width="13" Height="13" Margin="7,0,0,0" />
                    </StackPanel>
                </Button>

                <Popup x:Name="ModelPickerPopup" IsOpen="{Binding IsModelPickerOpen, Mode=TwoWay}" PlacementTarget="{Binding ElementName=ModelPickerButton}" Placement="Bottom"
                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" Focusable="True" Opened="ModelPickerPopup_Opened">
                    <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1" CornerRadius="10"
                            Width="440" MaxHeight="500" Margin="0,4,0,0" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="18" ShadowDepth="3" Opacity="0.5" Color="Black" />
                        </Border.Effect>
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                <TextBox x:Name="ModelSearchBox" Text="{Binding ModelSearchText, UpdateSourceTrigger=PropertyChanged}" Tag="모델 검색…" Padding="30,7,10,7" />
                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSearch}" Width="15" Height="15" HorizontalAlignment="Left" Margin="9,0,0,0"
                                      Fill="{StaticResource MutedForegroundBrush}" IsHitTestVisible="False" />
                            </Grid>
                            <ListBox Grid.Row="1" ItemsSource="{Binding ModelsView}" SelectedItem="{Binding SelectedModel}" Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled" PreviewMouseLeftButtonUp="ModelList_MouseUp">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="11" FontWeight="SemiBold" Margin="10,8,0,3" />
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource ForegroundBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Id}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="10.5" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Popup>

                <Button Command="{Binding RefreshModelsCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" Margin="2,0,0,0" ToolTip="모델 목록 새로고침">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconRefresh}" Width="16" Height="16" />
                </Button>
                <TextBlock Text="불러오는 중…" Foreground="{StaticResource MutedForegroundBrush}" VerticalAlignment="Center" FontSize="11.5" Margin="6,0,0,0"
                           Visibility="{Binding IsModelLoading, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Button HorizontalAlignment="Right" Command="{Binding OpenSettingsCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="10,6" ToolTip="설정">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSettings}" Width="16" Height="16" />
                    <TextBlock Text="설정" Margin="7,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </views:WindowView.TitleBarContent>

    <!-- ================= 본문 ================= -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== 좌측 사이드바 ===== -->
        <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0" ClipToBounds="True">
            <Grid Width="279">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Command="{Binding NewConversationCommand}" Style="{StaticResource AccentButtonStyle}" Margin="12,12,12,6" Padding="12,9">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPlus}" Width="15" Height="15" />
                        <TextBlock Text="새 대화" Margin="7,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Grid Grid.Row="1" Margin="12,4,12,6">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Tag="대화 검색…" FontSize="12.5" Padding="30,6,8,6" />
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSearch}" Width="14" Height="14" HorizontalAlignment="Left" Margin="9,0,0,0"
                          Fill="{StaticResource MutedForegroundBrush}" IsHitTestVisible="False" />
                </Grid>

                <ListBox Grid.Row="2" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding ConversationsView}" SelectedItem="{Binding SelectedConversation}"
                         HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="11" FontWeight="SemiBold" Margin="14,10,0,3" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ConversationViewModel}">
                            <Grid x:Name="ConvRow" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel x:Name="DisplayPanel" Grid.Column="0">
                                    <!-- StackPanel 은 자식에게 무한 폭을 주어 TextTrimming 이 동작하지 않으므로 Grid 로 폭을 제한한다. -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0" Data="{StaticResource IconPin}" Width="11" Height="11" Stretch="Uniform" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,5,0"
                                              Visibility="{Binding Pinned, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{StaticResource ForegroundBrush}" FontSize="13"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" ToolTip="{Binding Title}" />
                                    </Grid>
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock x:Name="ConvSubtitle" Text="{Binding Subtitle}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                        <!-- 응답 생성 중 표시 -->
                                        <StackPanel x:Name="ConvBusy" Orientation="Horizontal" Visibility="Collapsed">
                                            <Ellipse x:Name="BDot1" Width="5" Height="5" Margin="0,0,4,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                            <Ellipse x:Name="BDot2" Width="5" Height="5" Margin="0,0,4,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                            <Ellipse x:Name="BDot3" Width="5" Height="5" Margin="0,0,6,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                            <TextBlock Text="응답 생성 중" Foreground="{StaticResource AccentBrush}" FontSize="11" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <TextBox x:Name="RenamePanel" Grid.Column="0" Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}" Visibility="Collapsed" Padding="6,4" FontSize="13"
                                         behaviors:FocusBehavior.FocusWhenVisible="True" KeyDown="RenameBox_KeyDown" LostFocus="RenameBox_LostFocus" />

                                <StackPanel x:Name="Actions" Grid.Column="1" Orientation="Horizontal" Visibility="Hidden">
                                    <Button Command="{Binding DataContext.PinConversationCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}" Padding="6" ToolTip="고정/해제">
                                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPin}" Width="14" Height="14" />
                                    </Button>
                                    <Button Command="{Binding DataContext.BeginRenameCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}" Padding="6" ToolTip="이름 변경">
                                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPencil}" Width="14" Height="14" />
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteConversationCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}" Padding="6" ToolTip="삭제">
                                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconDelete}" Width="14" Height="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="ConvRow" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Actions" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                    <Setter TargetName="ConvSubtitle" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="ConvBusy" Property="Visibility" Value="Visible" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard x:Name="ConvBusySb">
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="BDot1" Storyboard.TargetProperty="Opacity" From="0.35" To="1" Duration="0:0:0.45" AutoReverse="True" />
                                                <DoubleAnimation Storyboard.TargetName="BDot2" Storyboard.TargetProperty="Opacity" From="0.35" To="1" BeginTime="0:0:0.15" Duration="0:0:0.45" AutoReverse="True" />
                                                <DoubleAnimation Storyboard.TargetName="BDot3" Storyboard.TargetProperty="Opacity" From="0.35" To="1" BeginTime="0:0:0.3" Duration="0:0:0.45" AutoReverse="True" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="ConvBusySb" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter TargetName="DisplayPanel" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="Actions" Property="Visibility" Value="Collapsed" />
                                    <Setter TargetName="RenamePanel" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="3">
                    <!-- 업데이트 안내. 대화 목록 아래에 두어 채팅을 가리지 않는다. -->
                    <Border Margin="12,6,12,2" Padding="10,8" CornerRadius="8"
                            Background="{StaticResource ControlBackgroundBrush}" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="{StaticResource IconArrowDown}" Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                                <TextBlock Grid.Column="1" Text="{Binding UpdateText}" Foreground="{StaticResource ForegroundBrush}" FontSize="11.5" TextWrapping="Wrap" VerticalAlignment="Center" />
                                <Button Grid.Column="2" Command="{Binding DismissUpdateCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="4" Margin="4,0,0,0" ToolTip="나중에"
                                        Visibility="{Binding IsUpdateIdle, Converter={StaticResource BoolToVis}}">
                                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}" Width="10" Height="10" />
                                </Button>
                            </Grid>

                            <!-- 대기 상태: 설치 버튼 -->
                            <Button x:Name="UpdateButton" Command="{Binding InstallUpdateCommand}" Style="{StaticResource AccentButtonStyle}" Content="지금 업데이트"
                                    Padding="0,6" Margin="0,8,0,0" FontSize="12"
                                    Visibility="{Binding IsUpdateIdle, Converter={StaticResource BoolToVis}}" />

                            <!-- 진행 상태: 진행률 -->
                            <StackPanel Margin="0,8,0,0" Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}">
                                <ProgressBar Value="{Binding UpdateProgress, Mode=OneWay}" Maximum="100" Style="{StaticResource MeterProgressStyle}" />
                                <TextBlock Text="{Binding UpdateProgressText}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="10.5" Margin="0,5,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 잔여 할당량은 API 로 알 수 없으므로(실측 확인) 이 앱이 보낸 사용량만 담백하게 적는다. -->
                    <TextBlock Text="{Binding UsageTodayText}" ToolTip="{Binding UsageTooltip}"
                               Foreground="{StaticResource MutedForegroundBrush}" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,10" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 우측: 채팅 영역 ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 헤더 -->
            <Grid Grid.Row="0" Margin="20,14,20,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding SelectedConversation.Title}" Foreground="{StaticResource ForegroundBrush}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding ToggleAdvancedCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" ToolTip="시스템 프롬프트 · 파라미터">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconTune}" Width="17" Height="17" />
                    </Button>
                    <Button Command="{Binding RegenerateLastCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" ToolTip="마지막 응답 다시 생성">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconRefresh}" Width="17" Height="17" />
                    </Button>
                    <Button Command="{Binding CopyConversationCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" ToolTip="대화 전체 복사">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconCopy}" Width="17" Height="17" />
                    </Button>
                    <Button Command="{Binding ExportConversationCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" ToolTip="Markdown 으로 내보내기">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconExport}" Width="17" Height="17" />
                    </Button>
                    <Button Command="{Binding ClearMessagesCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="8" ToolTip="메시지 비우기">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconDelete}" Width="17" Height="17" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 고급 패널 -->
            <Border Grid.Row="1" Margin="20,4,20,4" Padding="16" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10"
                    Visibility="{Binding IsAdvancedOpen, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="시스템 프롬프트" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="12" Margin="0,0,0,5" />
                    <TextBox Text="{Binding SelectedConversation.SystemPrompt, UpdateSourceTrigger=PropertyChanged}" Tag="이 대화에서 AI의 역할/지침 (선택)" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="54" MaxHeight="120" VerticalScrollBarVisibility="Auto" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Temperature" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="12" />
                                <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="12" Text="{Binding Value, ElementName=TemperatureSlider, StringFormat=F2}" />
                            </Grid>
                            <Slider x:Name="TemperatureSlider" Minimum="0" Maximum="2" SmallChange="0.01" LargeChange="0.1" Value="{Binding SelectedConversation.Parameters.Temperature, Mode=TwoWay}" Margin="0,0,0,14" />
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Top P" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="12" />
                                <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="12" Text="{Binding Value, ElementName=TopPSlider, StringFormat=F2}" />
                            </Grid>
                            <Slider x:Name="TopPSlider" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1" Value="{Binding SelectedConversation.Parameters.TopP, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="최대 토큰" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="12" />
                                <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="12" Text="{Binding Value, ElementName=MaxTokensSlider, StringFormat=F0}" />
                            </Grid>
                            <Slider x:Name="MaxTokensSlider" Minimum="256" Maximum="8192" SmallChange="128" LargeChange="512" Value="{Binding SelectedConversation.Parameters.MaxTokens, Mode=TwoWay}" Margin="0,0,0,14" />
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Frequency Penalty" Foreground="{StaticResource SecondaryForegroundBrush}" FontSize="12" />
                                <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="12" Text="{Binding Value, ElementName=FreqSlider, StringFormat=F2}" />
                            </Grid>
                            <Slider x:Name="FreqSlider" Minimum="-2" Maximum="2" SmallChange="0.01" LargeChange="0.1" Value="{Binding SelectedConversation.Parameters.FrequencyPenalty, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 상태 배너 -->
            <Border Grid.Row="2" Margin="20,4,20,4" Padding="12,9" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource WarnBrush}" BorderThickness="1" CornerRadius="8"
                    Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Path Grid.Column="0" Data="{StaticResource IconAlert}" Width="16" Height="16" Stretch="Uniform" Fill="{StaticResource WarnBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12.5" />
                    <Button Grid.Column="2" Command="{Binding OpenSettingsCommand}" Style="{StaticResource SubtleButtonStyle}" Content="설정 열기" Margin="10,0,0,0"
                            Visibility="{Binding HasApiKey, Converter={StaticResource InverseBoolToVis}}" />
                </Grid>
            </Border>

            <!-- 메시지 목록 -->
            <Grid Grid.Row="3">
                <ScrollViewer x:Name="MessagesScroller" VerticalScrollBarVisibility="Auto" Padding="20,6,14,6"
                              behaviors:AutoScrollBehavior.IsEnabled="True" ScrollChanged="MessagesScroller_ScrollChanged">
                    <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ChatMessageViewModel}">
                                <Grid x:Name="MsgRow" Margin="0,7">
                                    <!-- Background=Transparent 로 말풍선+여백+(숨겨진)액션 영역 전체를 히트테스트 대상으로 만들어
                                         마우스를 버튼으로 내려도 호버가 끊기지 않게 한다. -->
                                    <StackPanel x:Name="Column" HorizontalAlignment="Left" MaxWidth="840" Background="Transparent">
                                        <!-- 말풍선: 내용만 감싼다 -->
                                        <Border x:Name="Bubble" Background="{StaticResource AssistantBubbleBackgroundBrush}" BorderBrush="{StaticResource AssistantBubbleBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14,10" HorizontalAlignment="Left">
                                            <StackPanel>
                                                <!-- 첨부 이미지 -->
                                                <ItemsControl ItemsSource="{Binding ImageSources}" Margin="0,0,0,8" Visibility="{Binding HasImages, Converter={StaticResource BoolToVis}}">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border CornerRadius="8" Margin="0,0,6,6" ClipToBounds="True" MaxHeight="240" MaxWidth="300" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                                <Image Source="{Binding}" Stretch="Uniform" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- 추론 섹션 -->
                                                <StackPanel x:Name="ReasoningBox" Visibility="Collapsed" Margin="0,0,0,8">
                                                    <Button Command="{Binding ToggleReasoningCommand}" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Left" Padding="6,3">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path x:Name="ReasoningChevron" Style="{StaticResource IconStyle}" Data="{StaticResource IconChevronRight}" Width="12" Height="12" />
                                                            <TextBlock Text="추론 과정" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" />
                                                        </StackPanel>
                                                    </Button>
                                                    <Border x:Name="ReasoningBody" Visibility="Collapsed" Background="{StaticResource CodeBlockBackgroundBrush}" CornerRadius="6" Padding="10,8" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding Reasoning}" Foreground="{StaticResource SecondaryForegroundBrush}" TextWrapping="Wrap" FontSize="12.5" LineHeight="19" />
                                                    </Border>
                                                </StackPanel>

                                                <!-- 편집 모드 -->
                                                <StackPanel x:Name="EditPanel" Visibility="Collapsed">
                                                    <TextBox Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinWidth="360" MaxHeight="240" VerticalScrollBarVisibility="Auto" behaviors:FocusBehavior.FocusWhenVisible="True" />
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                                        <Button Content="취소" Command="{Binding CancelEditCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="12,5" Margin="0,0,8,0" />
                                                        <Button Content="저장 후 재생성" Style="{StaticResource AccentButtonStyle}" Padding="14,5"
                                                                Command="{Binding DataContext.SubmitEditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- 본문 -->
                                                <TextBlock x:Name="RawText" Text="{Binding Content}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap"
                                                           Visibility="{Binding ShowMarkdown, Converter={StaticResource InverseBoolToVis}}" />
                                                <controls:MarkdownPresenter x:Name="Markdown" Markdown="{Binding Content}" Visibility="{Binding ShowMarkdown, Converter={StaticResource BoolToVis}}" />

                                                <!-- 타이핑 대기 애니메이션: 텍스트 한 줄 높이 안에서 점만 움직인다 -->
                                                <StackPanel x:Name="Typing" Orientation="Horizontal" Visibility="Collapsed" Height="19" VerticalAlignment="Center">
                                                    <Ellipse x:Name="Dot1" Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                                    <Ellipse x:Name="Dot2" Width="7" Height="7" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                                    <Ellipse x:Name="Dot3" Width="7" Height="7" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                                </StackPanel>

                                                <Border x:Name="AbortedChip" Visibility="Collapsed" HorizontalAlignment="Left" Margin="0,6,0,0" Padding="6,2" CornerRadius="4" Background="{StaticResource InlineCodeBackgroundBrush}">
                                                    <TextBlock Text="중단됨" Foreground="{StaticResource MutedForegroundBrush}" FontSize="11" />
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <!-- 액션바: 말풍선 밖 하단 -->
                                        <StackPanel x:Name="MsgActions" Orientation="Horizontal" Margin="4,4,4,0" HorizontalAlignment="Left" Visibility="Hidden">
                                            <Button Command="{Binding CopyCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="6,3" ToolTip="복사">
                                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconCopy}" Width="14" Height="14" />
                                            </Button>
                                            <Button x:Name="EditBtn" Command="{Binding BeginEditCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="6,3" Visibility="Collapsed" ToolTip="편집 후 재생성">
                                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconPencil}" Width="14" Height="14" />
                                            </Button>
                                            <Button x:Name="RegenBtn" Command="{Binding DataContext.RegenerateMessageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"
                                                    Style="{StaticResource SubtleButtonStyle}" Padding="6,3" Visibility="Collapsed" ToolTip="다시 생성">
                                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconRefresh}" Width="14" Height="14" />
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteMessageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"
                                                    Style="{StaticResource SubtleButtonStyle}" Padding="6,3" ToolTip="삭제">
                                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconDelete}" Width="14" Height="14" />
                                            </Button>
                                            <TextBlock Text="{Binding TimestampText}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="Column" Property="HorizontalAlignment" Value="Right" />
                                        <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                        <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubbleBackgroundBrush}" />
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource UserBubbleBorderBrush}" />
                                        <Setter TargetName="MsgActions" Property="HorizontalAlignment" Value="Right" />
                                        <Setter TargetName="EditBtn" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                                        <Setter TargetName="RegenBtn" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasReasoning}" Value="True">
                                        <Setter TargetName="ReasoningBox" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsReasoningExpanded}" Value="True">
                                        <Setter TargetName="ReasoningBody" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="ReasoningChevron" Property="Data" Value="{StaticResource IconChevronDown}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter TargetName="RawText" Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource ErrorBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Aborted}" Value="True">
                                        <Setter TargetName="AbortedChip" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                        <Setter TargetName="Typing" Property="Visibility" Value="Visible" />
                                        <!-- 대기 중에는 빈 본문이 한 줄을 차지하지 않도록 숨겨 말풍선을 한 줄 높이로 유지 -->
                                        <Setter TargetName="RawText" Property="Visibility" Value="Collapsed" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="TypingSb">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity" From="0.35" To="1" Duration="0:0:0.45" AutoReverse="True" />
                                                    <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity" From="0.35" To="1" BeginTime="0:0:0.15" Duration="0:0:0.45" AutoReverse="True" />
                                                    <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity" From="0.35" To="1" BeginTime="0:0:0.3" Duration="0:0:0.45" AutoReverse="True" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="TypingSb" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <!-- 호버 트리거를 먼저 두고, 편집 중 숨김을 뒤에 둬서(나중 선언 우선) 편집 중에는 액션바가 뜨지 않게 한다. -->
                                    <Trigger SourceName="MsgRow" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MsgActions" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter TargetName="EditPanel" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="RawText" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="Markdown" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="MsgActions" Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 빈 상태 -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="560"
                            Visibility="{Binding SelectedConversation.IsEmpty, Converter={StaticResource BoolToVis}}">
                    <Image Source="pack://application:,,,/NvChat;component/Resources/brand.png" Width="60" Height="60" HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="무엇이든 물어보세요" Foreground="{StaticResource ForegroundBrush}" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,4" />
                    <TextBlock Text="NVIDIA 의 무료 LLM 으로 대화를 시작합니다." Foreground="{StaticResource MutedForegroundBrush}" FontSize="12.5" HorizontalAlignment="Center" Margin="0,0,0,18" />
                    <ItemsControl ItemsSource="{Binding ExamplePrompts}" HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel HorizontalAlignment="Center" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Margin="5" Command="{Binding DataContext.UseExamplePromptCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 맨 아래로 -->
                <Button x:Name="ScrollToBottomButton" Click="ScrollToBottomButton_Click" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,22,10" Width="36" Height="36"
                        Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderStrongBrush}" Foreground="{StaticResource ForegroundBrush}" ToolTip="맨 아래로">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="18">
                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconArrowDown}" Width="18" Height="18" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource ControlHoverBackgroundBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- ===== 입력 (Claude 식: 상단 텍스트 + 하단 툴바) ===== -->
            <Border Grid.Row="4" Margin="20,6,20,16" Padding="10,8" Background="{StaticResource ControlBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14">
                <StackPanel>
                    <TextBox x:Name="InputBox" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="메시지를 입력하세요…   (Enter 전송 · Shift+Enter 줄바꿈)" Background="Transparent" BorderThickness="0" Padding="2,2,2,4"
                             AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="220" VerticalScrollBarVisibility="Auto" PreviewKeyDown="InputBox_PreviewKeyDown" />

                    <!-- 첨부 미리보기 -->
                    <ItemsControl ItemsSource="{Binding Attachments}" Margin="0,4,0,2" Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,6,4" Width="60" Height="60">
                                    <Border CornerRadius="6" ClipToBounds="True" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                        <Image Source="{Binding Preview}" Stretch="UniformToFill" />
                                    </Border>
                                    <Button Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}"
                                            Style="{StaticResource SubtleButtonStyle}" Foreground="White" Background="#B0000000" Width="18" Height="18" Padding="0"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0" ToolTip="제거">
                                        <Path Data="{StaticResource IconClose}" Width="10" Height="10" Stretch="Uniform" Fill="White" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 툴바 행 -->
                    <Grid Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Command="{Binding AttachImageCommand}" Style="{StaticResource SubtleButtonStyle}" Padding="7" ToolTip="이미지 첨부 (비전 모델)">
                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconAttach}" Width="19" Height="19" />
                            </Button>
                            <Button x:Name="PresetButton" Click="PresetButton_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,6" ToolTip="프롬프트 프리셋">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconTune}" Width="15" Height="15" />
                                    <TextBlock Text="프리셋" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12.5" />
                                </StackPanel>
                            </Button>

                            <!-- 전송이 막힌 이유 안내 -->
                            <TextBlock Foreground="{StaticResource MutedForegroundBrush}" FontSize="11.5" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"
                                       Text="{Binding StreamingConversationTitle, StringFormat='‘{0}’ 대화에서 응답을 생성 중이에요. 끝나면 전송할 수 있어요.'}"
                                       Visibility="{Binding IsSendBlockedByOtherConversation, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <Button HorizontalAlignment="Right" Command="{Binding SendCommand}" Style="{StaticResource AccentButtonStyle}" Padding="14,7"
                                Visibility="{Binding IsSelectedStreaming, Converter={StaticResource InverseBoolToVis}}" ToolTip="전송">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="전송" VerticalAlignment="Center" />
                                <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSend}" Width="15" Height="15" Margin="7,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button HorizontalAlignment="Right" Command="{Binding StopCommand}" Style="{StaticResource {x:Type Button}}" Padding="14,7"
                                Visibility="{Binding IsSelectedStreaming, Converter={StaticResource BoolToVis}}" ToolTip="중단">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconStop}" Width="14" Height="14" Stretch="Uniform" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                                <TextBlock Text="중단" Margin="7,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</views:WindowView>
