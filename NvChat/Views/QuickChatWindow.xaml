<views:WindowView
    x:Class="NvChat.Views.QuickChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:NvChat.Views"
    xmlns:vm="clr-namespace:NvChat.ViewModels"
    xmlns:controls="clr-namespace:NvChat.Controls"
    xmlns:behaviors="clr-namespace:NvChat.Behaviors"
    mc:Ignorable="d"
    Title="빠른 채팅"
    Width="660"
    Height="560"
    MinWidth="460"
    MinHeight="360"
    ShowMinimizeButton="False"
    ShowMaximizeButton="False"
    ShowCloseButton="False"
    Topmost="True"
    ShowInTaskbar="False"
    Style="{StaticResource NvWindowStyle}"
    WindowStartupLocation="Manual"
    d:DataContext="{d:DesignInstance vm:MainViewModel}"
    >
    <views:WindowView.TitleBarContent>
        <Grid Margin="6,0,4,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image Source="pack://application:,,,/NvChat;component/Resources/brand.png" Width="18" Height="18" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="빠른 채팅" Foreground="{StaticResource ForegroundBrush}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0" />
                <TextBlock Text="{Binding SelectedModel.Name}" Foreground="{StaticResource MutedForegroundBrush}" FontSize="11.5" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="220" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Click="OpenMain_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8,5" ToolTip="메인 창 열기">
                    <StackPanel Orientation="Horizontal">
                        <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconChat}" Width="14" Height="14" />
                        <TextBlock Text="메인 열기" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12" />
                    </StackPanel>
                </Button>
                <Button Click="Close_Click" Style="{StaticResource SubtleButtonStyle}" Padding="8" Margin="2,0,4,0" ToolTip="닫기 (Esc)">
                    <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconClose}" Width="13" Height="13" />
                </Button>
            </StackPanel>
        </Grid>
    </views:WindowView.TitleBarContent>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="16,10,10,6" behaviors:AutoScrollBehavior.IsEnabled="True">
            <ItemsControl ItemsSource="{Binding SelectedConversation.Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ChatMessageViewModel}">
                        <Grid Margin="0,5">
                            <Border x:Name="Bubble" HorizontalAlignment="Left" MaxWidth="560" Background="{StaticResource AssistantBubbleBackgroundBrush}" BorderBrush="{StaticResource AssistantBubbleBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12,9">
                                <StackPanel>
                                    <TextBlock x:Name="RawText" Text="{Binding Content}" Foreground="{StaticResource ForegroundBrush}" TextWrapping="Wrap"
                                               Visibility="{Binding ShowMarkdown, Converter={StaticResource InverseBoolToVis}}" />
                                    <controls:MarkdownPresenter x:Name="Markdown" Markdown="{Binding Content}" Visibility="{Binding ShowMarkdown, Converter={StaticResource BoolToVis}}" />
                                    <StackPanel x:Name="Typing" Orientation="Horizontal" Visibility="Collapsed" Height="18" VerticalAlignment="Center">
                                        <Ellipse x:Name="Dot1" Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                        <Ellipse x:Name="Dot2" Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                        <Ellipse x:Name="Dot3" Width="6" Height="6" VerticalAlignment="Center" Fill="{StaticResource AccentBrush}" Opacity="0.35" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Grid.Style>
                                <Style TargetType="Grid" />
                            </Grid.Style>
                        </Grid>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Bubble" Property="Background" Value="{StaticResource UserBubbleBackgroundBrush}" />
                                <Setter TargetName="Bubble" Property="BorderBrush" Value="{StaticResource UserBubbleBorderBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter TargetName="RawText" Property="Foreground" Value="{StaticResource ErrorBrush}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsWaiting}" Value="True">
                                <Setter TargetName="Typing" Property="Visibility" Value="Visible" />
                                <Setter TargetName="RawText" Property="Visibility" Value="Collapsed" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard x:Name="QSb">
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity" From="0.35" To="1" Duration="0:0:0.45" AutoReverse="True" />
                                            <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity" From="0.35" To="1" BeginTime="0:0:0.15" Duration="0:0:0.45" AutoReverse="True" />
                                            <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity" From="0.35" To="1" BeginTime="0:0:0.3" Duration="0:0:0.45" AutoReverse="True" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="QSb" />
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" Margin="12,4,12,12" Padding="10,8" Background="{StaticResource ControlBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12">
            <StackPanel>
                <TextBox x:Name="QuickInput" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}" Tag="빠르게 물어보세요…" Background="Transparent" BorderThickness="0" Padding="2"
                         AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="140" VerticalScrollBarVisibility="Auto" PreviewKeyDown="QuickInput_PreviewKeyDown" />
                <Grid Margin="0,4,0,0">
                    <Button HorizontalAlignment="Right" Command="{Binding SendCommand}" Style="{StaticResource AccentButtonStyle}" Padding="14,6"
                            Visibility="{Binding IsSelectedStreaming, Converter={StaticResource InverseBoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="전송" VerticalAlignment="Center" />
                            <Path Style="{StaticResource IconStyle}" Data="{StaticResource IconSend}" Width="14" Height="14" Margin="7,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button HorizontalAlignment="Right" Command="{Binding StopCommand}" Style="{StaticResource {x:Type Button}}" Padding="14,6"
                            Visibility="{Binding IsSelectedStreaming, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconStop}" Width="13" Height="13" Stretch="Uniform" Fill="{StaticResource ErrorBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="중단" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</views:WindowView>
